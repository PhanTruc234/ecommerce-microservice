// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CartStatus {
  ACTIVE // đang mua hàng
  CHECKED_OUT // đã thanh toán
  LOCKED // giữ hàng
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  items     CartItem[]
}

model CartItem {
  id        String @id @default(cuid())
  cartId    String
  variantId String

  quantity       Int        @default(1)
  status         CartStatus @default(ACTIVE)
  price          Decimal    @db.Decimal(18, 2)
  discountAmount Decimal?   @default(0) @db.Decimal(18, 2)
  finalPrice     Decimal    @db.Decimal(18, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)

  @@unique([cartId, variantId])
  @@index([cartId])
  @@index([variantId])
}

enum OrderStatus {
  PENDING // mới tạo, chờ xử lý
  CONFIRMED // shop xác nhận
  PROCESSING // đang chuẩn bị hàng
  SHIPPING // đang giao
  DELIVERED // đã giao
  CANCELLED // đã hủy
}

enum PaymentStatus {
  UNPAID // chưa thanh toán
  PAID // đã thanh toán
  FAILED // thất bại
}

enum PaymentMethod {
  COD
  BANK_TRANSFER
  MOMO
  VNPAY
}

model Order {
  id        String @id @default(cuid())
  orderCode String @unique

  userId String

  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID)
  paymentMethod PaymentMethod @default(COD)

  subtotal       Decimal @db.Decimal(18, 2)
  discountAmount Decimal @default(0) @db.Decimal(18, 2)
  shippingFee    Decimal @default(0) @db.Decimal(18, 2)
  totalAmount    Decimal @db.Decimal(18, 2)

  receiverName  String
  receiverPhone String
  addressLine   String
  ward          String?
  province      String
  note          String?

  paidAt          DateTime?
  cancelledAt     DateTime?
  deliveredAt     DateTime?
  stockRestoredAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  items OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  variantId String?

  productName String
  variantSku  String
  imageUrl    String?

  size  String?
  color String?

  quantity       Int
  price          Decimal @db.Decimal(18, 2)
  discountAmount Decimal @default(0) @db.Decimal(18, 2)
  finalPrice     Decimal @db.Decimal(18, 2)

  createdAt DateTime @default(now())
  productId String?

  @@index([orderId])
  @@index([variantId])
}
